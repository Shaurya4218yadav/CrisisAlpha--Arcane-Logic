# Server
PORT=3001

# To enable generation of intelligent Situation Reports (SitReps),
# provide an API key from Google AI Studio. 
# Get one free here: https://aistudio.google.com/
# If GEMINI_API_KEY is left as "mock" or missing, 
# the AI service will return placeholder reports.
GEMINI_API_KEY="mock"
